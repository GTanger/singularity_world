      }
    }
  ],

  "life_xuan_1": [
    {
      "id": "life_xuan_1_scrolls",
      "name": "捲軸典籍",
      "owner": "inn",
      "sockets": ["Look", "Read"],
      "responses": {
        "Look": "屋內擺滿了各式各樣的捲軸與殘缺的典籍，有的攤開在案上，有的插在竹筒裡，紙張泛黃卻保存得當。",
        "Read": "你隨手翻開一冊，字跡工整卻難以全識，似是古時修煉心法或地方志異的抄本，墨香與紙張的氣味混在一起。"
      }
    },
