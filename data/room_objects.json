      "id": "life_xuan_1_incense",
      "name": "安神香",
      "owner": "inn",
      "sockets": ["Look", "Smell"],
      "responses": {
        "Look": "屋角燃著一支安神香，細長的香柱頂端一點紅光，青煙緩緩騰起，在古銅色的牆壁前繚繞不散。",
        "Smell": "你深吸一口氣，安神香的氣味沉靜溫和，帶著一絲藥草與檀木的餘韻，令人心神稍定。"
      }
    }
  ]
