{
  "_說明": "房間非人物件定義。id 全域唯一，sockets 為可用動詞（Look/Read 最小集）。name 須與房間描述中 〔〕 內文字一致。",

  "life_hall": [
    {
      "id": "life_hall_lantern",
      "name": "六角宮燈",
      "owner": "inn",
      "sockets": ["Look"],
      "responses": {
        "Look": "你抬頭端詳那盞六角宮燈。燈罩以薄絹繃製，繪有松鶴延年的紋樣，燭火搖曳間，六個面輪流明滅，在天花板上投下旋轉的光影。"
      }
    },
    {
      "id": "life_hall_plaque",
      "name": "匾額",
      "owner": "inn",
      "sockets": ["Look", "Read"],
      "responses": {
        "Look": "匾額掛在櫃台正上方，寬約三尺，厚實的檀木板面已被歲月磨出深沉的包漿。",
        "Read": "匾上以行草寫著【浮生】二字，筆勢蒼勁飛揚，落款處隱約可見一枚朱紅小印，年代已不可考。"
      }
    },
    {
      "id": "life_hall_board",
      "name": "佈告欄",
      "owner": "",
      "sockets": ["Look", "Read"],
      "responses": {
        "Look": "一塊半人高的木板立在角落，邊框已被摸得發黑。上面釘滿了大小不一的紙條，有的已經泛黃捲曲。",
        "Read": "你湊近端詳紙條上的內容：有尋人啟事、有旅隊招募告示、有一張寫滿咒罵文字的匿名投書……最新的一張寫著「酒窖新到一批陳年桂花釀，欲購從速」。"
      }
    }
  ],

  "life_dining": [
    {
      "id": "life_dining_tables",
      "name": "方桌",
      "owner": "inn",
      "sockets": ["Look"],
      "responses": {
        "Look": "七八張方桌錯落擺放，桌面被擦得發亮，邊角磨得圓潤。有的桌上還擺著未收的茶盞與筷箸。"
      }
    },
    {
      "id": "life_dining_steamer",
      "name": "蒸籠",
      "owner": "inn",
      "sockets": ["Look", "Smell"],
      "responses": {
        "Look": "牆角的灶台上蒸籠一層疊著一層，白煙嫋嫋從縫隙間鑽出，帶著米麵與餡料的香氣。",
        "Smell": "你深吸一口氣，蒸氣裡混著包子與饅頭的麥香，還有淡淡的竹篾氣味。"
      }
    }
  ],

