{
  "_說明": "浮生客棧房間定義檔。伺服器啟動時自動同步進 DB。直接編輯此檔後重啟即可。",
  "_格式": "rooms: 房間清單；exits: 出口清單，雙向要寫兩筆。direction 就是前端按鈕上顯示的文字。tags: 房間標籤供 NPC 尋路決策。zone: 所屬區域。",

  "rooms": [
    { "id": "lobby",        "name": "界壁",       "tags": ["spawn"],                          "zone": "界壁",     "description": "四周一片漆黑，伸手不見五指，唯一能見到的就是遠處極亮的光點。" },
    { "id": "life_garden",       "name": "假山庭院",   "tags": ["outdoor", "garden", "gate"],      "zone": "浮生客棧", "description": "嶙峋的假山錯落有致，陰影層層疊疊遮蔽了來路。幾叢翠竹從石縫間抽出，風過沙沙作響，掩去了一切細碎的腳步聲。" },
    { "id": "life_hall",         "name": "浮生大廳",   "tags": ["inn", "lobby", "social", "trade"], "zone": "浮生客棧", "description": "挑高的大廳中央懸著一盞〔六角宮燈〕，暖黃的光暈映在兩側的木柱上。櫃台後方掛著一面寫有【浮生】二字的〔匾額〕，墨跡蒼勁。角落立著一塊〔佈告欄〕，上頭釘滿了紙條。來往的旅人在此歇腳、打聽消息，或只是發呆望著門外。" },
    { "id": "life_dining",      "name": "喫食堂",     "tags": ["tavern", "food", "social"],       "zone": "浮生客棧", "description": "七八張〔方桌〕錯落擺放，桌面被擦得發亮。空氣裡飄著米飯與滷肉的香氣，牆角的灶台上〔蒸籠〕一層疊著一層，白煙嫋嫋。" },
    { "id": "life_kitchen",     "name": "廚房",       "tags": ["kitchen", "staff"],               "zone": "浮生客棧", "description": "灶火旺盛，鍋鏟碰撞聲不斷。幾口大鐵鍋架在〔灶台〕上，牆壁被油煙燻得發黑，但牆上〔刀具架〕與調料瓶排列得井井有條。" },
    { "id": "life_backyard",    "name": "後院",       "tags": ["outdoor", "staff"],               "zone": "浮生客棧", "description": "一方不大的天井，地面鋪著青石板。〔晾衣繩〕上掛著幾件粗布衣裳隨風擺動，角落裡堆著劈好的〔柴火〕，一株〔老槐樹〕撐起了半院的陰涼。" },
    { "id": "life_storage",     "name": "庫房",       "tags": ["storage", "staff", "rest"],       "zone": "浮生客棧", "description": "堆滿雜物的庫房，幾張〔行軍床〕擠在角落，是員工輪班休息的地方。〔木架〕上整齊碼放著米袋、鹽罐與備用的碗碟。" },
    { "id": "life_wine_cellar", "name": "酒窖",       "tags": ["storage", "tavern"],              "zone": "浮生客棧", "description": "沿著石階往下走，一股涼意撲面而來。〔陶甕〕與〔木桶〕沿牆排開，空氣中瀰漫著糧食發酵後的醇厚氣味，愈往深處酒香愈濃。" },
    { "id": "life_corridor_2f", "name": "二樓迴廊",   "tags": ["corridor", "lodging"],            "zone": "浮生客棧", "description": "木質迴廊環繞天井而建，〔欄杆〕上雕著簡樸的雲紋。腳下的地板踩上去微微作響，兩側排列著客房的〔門扉〕，門楣上分別掛著日、月、盈、昃的字牌。" },
    { "id": "life_corridor_3f", "name": "三樓迴廊",   "tags": ["corridor", "lodging"],            "zone": "浮生客棧", "description": "最高層的迴廊視野開闊，探頭便能望見遠處的屋脊與街巷。迴廊盡頭擺著一張長條茶几，幾把藤椅供客人在此賞景閒坐。門楣上掛著天、地、玄、黃的字牌。" },

    { "id": "life_ri_1",        "name": "日字一號房", "tags": ["room", "lodging"],                "zone": "浮生客棧", "description": "陽光透過正面的格柵灑在地面上，將空氣中的塵埃照得透亮。這間房正對著熱鬧的集市，即使關窗也能聽到外頭的吆喝聲，屋內透著乾爽的木頭味。" },
    { "id": "life_ri_2",        "name": "日字二號房", "tags": ["room", "lodging"],                "zone": "浮生客棧", "description": "採光稍弱，僅有一束斜光打在床頭。房間位於走廊內側，避開了街上的喧囂，顯得較為靜謐，牆角橫著兩根結實的木杆供人懸掛衣物。" },
    { "id": "life_yue_1",       "name": "月字一號房", "tags": ["room", "lodging"],                "zone": "浮生客棧", "description": "屋內的色調偏冷，微光從高處的通風孔斜射進來。房內空間較大，擺著一張圓形的石几，月光灑在其上呈現出一道銀色的軌跡，透著一股孤寂感。" },
    { "id": "life_yue_2",       "name": "月字二號房", "tags": ["room", "lodging"],                "zone": "浮生客棧", "description": "這是一個極窄的單人間，僅容下一張窄床與小几。家具的影子被油燈拉得極長且歪斜，空氣中帶著一絲經年不散的寒意。" },
    { "id": "life_ying_1",      "name": "盈字一號房", "tags": ["room", "lodging"],                "zone": "浮生客棧", "description": "房內陳設較多，除了基本的床鋪，還多了一組存放舊物的木架。空氣中混雜著各種乾草與布匹的氣味，雖然擁擠，卻有一種厚實的溫暖感。" },
    { "id": "life_ying_2",      "name": "盈字二號房", "tags": ["room", "lodging"],                "zone": "浮生客棧", "description": "這間房堆放了客棧備用的紅木長凳與成捆的柴薪，空間侷促。住在這裏像是身處雜物堆中，卻能感受到一種忙碌過後的真實生活壓力。" },
    { "id": "life_ze_1",        "name": "昃字一號房", "tags": ["room", "lodging"],                "zone": "浮生客棧", "description": "殘餘的紅光透過木窗將整間屋子染成暗橘色，能隱約聽到樓下後院傳來的馬嘶聲。牆上掛著一面灰暗的銅鏡，鏡面有些模糊。" },
    { "id": "life_ze_2",        "name": "昃字二號房", "tags": ["room", "lodging"],                "zone": "浮生客棧", "description": "位於樓層的死角，光線極其昏暗。影子在角落裡顯得比別處更濃，窗櫺上的木刺有些扎手，充滿了即將整理行囊離去的沉悶氣息。" },

    { "id": "life_tian_1",      "name": "天字一號房", "tags": ["room", "lodging", "luxury"],      "zone": "浮生客棧", "description": "頂層視野最開闊的房間。紅木大床掛著輕柔的湖縐紗幔，臨窗設有一張獨立的雕花書案，可在此俯瞰半座城鎮的青瓦屋頂與遠處燈火。" },
    { "id": "life_tian_2",      "name": "天字二號房", "tags": ["room", "lodging", "luxury"],      "zone": "浮生客棧", "description": "佈置更偏向休憩。窗邊配有一張極大的觀景靠椅，案几上擺著全套冰裂紋瓷器。陽光透過精緻的鏤空窗花，在牆上投下複雜的幾何影子。" },
    { "id": "life_di_1",        "name": "地字一號房", "tags": ["room", "lodging", "luxury"],      "zone": "浮生客棧", "description": "裝潢沉穩厚重，地面鋪著整塊厚實的羊毛毯。胡桃木家具散發著淡淡的油漆香，牆上掛著一幅寫意的山水圖，門窗閉合後隔音極佳。" },
    { "id": "life_di_2",        "name": "地字二號房", "tags": ["room", "lodging", "luxury"],      "zone": "浮生客棧", "description": "配有一座厚實的石砌臉盆架，水盆旁備有乾淨的棉布。房內的線條簡單卻紮實，大型木櫃透著木頭本身的微香，透出一種不容質疑的穩定感。" },
    { "id": "life_xuan_1",      "name": "玄字一號房", "tags": ["room", "lodging", "luxury", "study"], "zone": "浮生客棧", "description": "牆壁被漆成深邃的古銅色，屋內擺滿了各式各樣的〔捲軸典籍〕。屋角燃著一支〔安神香〕，青煙緩緩騰起，空氣中充滿了紙張與墨水的味道。" },
    { "id": "life_xuan_2",      "name": "玄字二號房", "tags": ["room", "lodging", "luxury"],      "zone": "浮生客棧", "description": "極其空曠，除了中央一張漆黑的蒲團外別無他物。光線在此被壓縮到極致，是一個安靜到讓人能聽見自己心跳的修煉之所。" },
    { "id": "life_huang_1",     "name": "黃字一號房", "tags": ["room", "lodging", "luxury"],      "zone": "浮生客棧", "description": "臨近樓梯口，佈置得樸實而舒適。窗櫺貼著泛黃的剪紙，擋住了塵土，床鋪鋪著乾淨的靛藍色粗布單，有一種讓人能安心歇腳的氣息。" },
    { "id": "life_huang_2",     "name": "黃字二號房", "tags": ["room", "lodging", "luxury"],      "zone": "浮生客棧", "description": "位於三樓走廊深處，窗外正對著後院的樹冠。雖然是高層最普通的房間，卻因其隱密性而深受歡迎，牆角擺著一盆生機盎然的小型綠植。" }
  ],

