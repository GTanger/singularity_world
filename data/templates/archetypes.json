      "trade_tendency": "buy_low_sell_high",
      "wealth_range": [80, 600],
      "goods_pool": ["布匹", "藥草", "食材", "雜貨", "香料", "茶葉"],
      "movement": {
        "type": "route",
        "speed": 1,
        "route_mode": "bounce",
        "_說明": "行腳商人沿城鎮間的路線巡迴買賣，waypoints 在行為模板中定義。"
      }
    },
    "blacksmith": {
