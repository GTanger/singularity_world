    "haggle_tolerance": 1,
    "haggle_texts": {
      "accept": [
        "【{name}】憨厚地點頭：「成，就這麼著。」",
        "【{name}】搓了搓手：「行吧，都是莊稼人。」",
        "【{name}】咧嘴笑道：「好說好說，成交。」"
      ],
      "reject": [
        "【{name}】搖頭：「這價不成，俺種地也不容易。」",
        "【{name}】皺眉：「再低就虧本了，不行。」",
        "【{name}】擺手：「算了算了，俺不賣了。」"
