      {"hour_start": 20, "hour_end": 22, "activity": "rest", "location_pref": ["farmhouse", "home"], "description": "回宅歇息"},
      {"hour_start": 22, "hour_end": 24, "activity": "sleep", "location_pref": ["farmhouse", "home"], "description": "早睡"}
    ]
  },
  "wander": {
    "preferred_locations": ["field", "rice_paddy", "farmhouse", "market", "life_hall", "life_dining"],
    "wander_chance": 0.2,
    "max_distance": 3,
    "leave_texts": [
      "【{name}】扛起農具，往{dest}方向走去。",
      "【{name}】拍了拍身上的泥土，往{dest}行去。",
      "【{name}】看了看日頭，往{dest}方向邁步。",
      "【{name}】收拾好籮筐，往{dest}而去。"
    ],
    "arrive_texts": [
      "【{name}】從{from}方向走了過來，身上帶著泥土與稻香。",
      "【{name}】自{from}而至，肩上還扛著農具。",
      "【{name}】從{from}走了進來，褲腳沾著泥點。",
      "【{name}】自{from}而來，手裡提著一籃剛摘的菜。"
    ]
  },
  "trade": {
    "buy_markup": 1.1,
    "sell_markup": 1.2,
    "preferred_goods": ["稻米", "蔬菜", "雞蛋", "粗鹽", "柴火", "豆子", "瓜果"],
