      {"hour_start": 6, "hour_end": 10, "activity": "work", "location_pref": ["field", "rice_paddy"], "description": "清晨田間勞作"},
      {"hour_start": 10, "hour_end": 12, "activity": "work", "location_pref": ["field", "rice_paddy", "vegetable_patch"], "description": "上午繼續農活"},
      {"hour_start": 12, "hour_end": 14, "activity": "rest", "location_pref": ["field", "farmhouse", "tree_shade"], "description": "田邊或樹下歇晌"},
