  "wander": {
    "preferred_locations": ["forge", "inn", "tavern"],
    "wander_chance": 0.08,
    "max_distance": 2,
    "leave_texts": [
      "【{name}】放下鐵錘，往{dest}方向走去。",
      "【{name}】擦了擦額頭的汗，邁步朝{dest}而去。",
      "【{name}】熄了爐火，轉身往{dest}方向離去。",
      "【{name}】解下圍裙，往{dest}方向踱去。"
    ],
    "arrive_texts": [
      "【{name}】從{from}方向走來，渾身帶著煙火氣。",
      "【{name}】自{from}方向大步而來，粗壯的手臂上沾著煤灰。",
      "【{name}】從{from}方向走來，目光在鐵器上掃過。",
      "【{name}】自{from}方向出現，手裡還拎著一壺酒。"
    ]
  },
  "trade": {
    "buy_markup": 0.5,
    "sell_markup": 1.3,
    "preferred_goods": ["鐵礦", "煤炭", "銅錠", "刀劍", "農具"],
    "refused_goods": ["布匹", "藥草"],
    "haggle_tolerance": 2,
    "haggle_texts": {
      "accept": [
        "【{name}】點了點頭：「成交。」",
        "【{name}】哼了一聲：「行，拿去吧。」",
        "【{name}】擦了擦手：「成，這價我認了。」",
        "【{name}】粗聲粗氣道：「好，就這麼著。」"
      ],
      "reject": [
        "【{name}】搖搖頭：「這價錢免談。」",
        "【{name}】把鐵錘往砧上一放：「你當我這鐵是泥捏的？」",
        "【{name}】瞪了你一眼：「這價連炭火錢都不夠，走吧。」",
        "【{name}】擺了擺手：「不成，這虧本買賣我不做。」"
      ],
      "counter": [
        "【{name}】伸出手指比了比：「再加點如何？」",
        "【{name}】敲了敲砧板：「實價在這，少一文都不行。」",
        "【{name}】皺起眉頭：「這已經是最低價了，再讓我就白忙活了。」",
        "【{name}】掂了掂手中的鐵器：「這可是好鋼，你再加些。」"
      ]
    }
  },
